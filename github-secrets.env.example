# PocketBudget GitHub Actions signing secrets template
# Copy values from this file into GitHub repository secrets.
# Do not commit any real secret values to this repository.

# Base64 of release keystore file
# Linux: base64 -w 0 path/to/release.keystore
# macOS: base64 path/to/release.keystore | tr -d '\n'
SIGNING_KEYSTORE_BASE64=PASTE_BASE64_KEYSTORE_HERE

# Keystore password
SIGNING_STORE_PASSWORD=PASTE_STORE_PASSWORD_HERE

# Keystore key alias
SIGNING_KEY_ALIAS=PASTE_KEY_ALIAS_HERE

# Key password
SIGNING_KEY_PASSWORD=PASTE_KEY_PASSWORD_HERE
