<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/img_category_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:padding="8dp"
                android:background="@drawable/bg_circle_button"
                app:tint="@color/brand_dark_green"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/text_category_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Groceries"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/text_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45%"
                android:textStyle="bold"
                android:textColor="@color/brand_dark_green"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_category"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progressDrawable="@drawable/bg_progress_bar_category"
            android:progress="45"
            android:max="100"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/text_spent_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ksh 4,500"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" spent of "
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
                
            <TextView
                android:id="@+id/text_limit_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ksh 10,000"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
                
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
                
            <TextView
                android:id="@+id/text_remaining_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ksh 5,500 left"
                android:textColor="@color/brand_secondary_green"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/text_forecast_alert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ On track to overspend"
            android:textSize="12sp"
            android:textColor="@color/brand_accent_orange"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:padding="4dp"
            android:background="#1AEE7600"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
