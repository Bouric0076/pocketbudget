<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background_gray">

    <!-- Scrollable Content (Placed first to be behind header by default, but elevation will fix z-order anyway) -->
    <!-- Actually, placing it first means it's drawn first. Header drawn later covers it. -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="320dp" 
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Quick Actions Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:padding="24dp">

                    <!-- Sync SMS (Primary) -->
                    <LinearLayout
                        android:id="@+id/action_sync"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_popup_sync"
                            android:background="@drawable/bg_circle_button"
                            android:padding="12dp"
                            app:tint="@color/brand_dark_green"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sync"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Add (Manual) -->
                    <LinearLayout
                        android:id="@+id/action_add"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_input_add"
                            android:background="@drawable/bg_circle_button"
                            android:padding="12dp"
                            app:tint="@color/brand_secondary_green"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Budget -->
                    <LinearLayout
                        android:id="@+id/action_budget"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            android:background="@drawable/bg_circle_button"
                            android:padding="12dp"
                            app:tint="#1976D2"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Budget"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Analytics -->
                    <LinearLayout
                        android:id="@+id/action_analytics"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            android:background="@drawable/bg_circle_button"
                            android:padding="12dp"
                            app:tint="#FFA000"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stats"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Top Recipients Section -->
            <LinearLayout
                android:id="@+id/layout_top_recipients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Top Recipients"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_top_recipients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_actor_spending"/>
            </LinearLayout>

            <!-- Recent Transactions Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Transactions"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                    
                <TextView
                    android:id="@+id/btn_see_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="@color/brand_light_green"
                    android:textStyle="bold"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="8dp"/>
            </LinearLayout>

            <!-- Transactions List -->
             <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recent_transactions" 
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_transaction"/>

            <!-- Empty State -->
            <include
                android:id="@+id/layout_empty_state"
                layout="@layout/layout_empty_state"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Header (Placed last to be on top) -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_rounded"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header: User & Notification -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <ImageView
                android:id="@+id/img_profile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_pocketbudget_logo" 
                android:background="@drawable/bg_circle_button"
                android:padding="10dp"
                app:tint="@color/brand_dark_green"/> 

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_profile"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to"
                    android:textColor="@color/text_on_dark"
                    android:alpha="0.8"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PocketBudget"
                    android:textColor="@color/text_on_dark"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/icon_privacy_eye"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/brand_light_green"
                    android:background="@drawable/bg_button_secondary"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/icon_notification"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="@color/brand_light_green"
                    android:background="@drawable/bg_button_secondary"
                    android:padding="8dp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Time Range Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:weightSum="4"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:id="@+id/tab_day"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Day"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_button_primary"
                android:textColor="@color/brand_dark_green"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"/>
                
            <TextView
                android:id="@+id/tab_week"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Week"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/text_on_dark"
                android:layout_marginEnd="4dp"/>
                
            <TextView
                android:id="@+id/tab_month"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Month"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/text_on_dark"
                android:layout_marginEnd="4dp"/>
                
            <TextView
                android:id="@+id/tab_year"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Year"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/text_on_dark"/>
        </LinearLayout>

        <!-- Financial Summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Income Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_button_secondary"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Income"
                        android:textColor="@color/brand_light_green"
                        android:textSize="12sp"
                        android:textAllCaps="true"/>
                        
                    <TextView
                        android:id="@+id/text_income_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ksh 0"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Expense Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_button_secondary"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spending"
                        android:textColor="#FF8A80" 
                        android:textSize="12sp"
                        android:textAllCaps="true"/>
                        
                    <TextView
                        android:id="@+id/text_expense_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ksh 0"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
            
            <!-- Net Balance -->
            <TextView
                android:id="@+id/text_balance_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Net: Ksh 0"
                android:textColor="@color/white"
                android:alpha="0.7"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:layout_gravity="center_horizontal"/>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
