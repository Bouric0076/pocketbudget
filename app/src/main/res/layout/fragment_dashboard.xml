<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ TOP BAR: iconPrivacyEye + iconNotification ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:id="@+id/imgUserAvatar"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="PocketBudget"
                    android:padding="7dp"
                    android:src="@drawable/ic_launcher_foreground"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/textGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome to"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif"/>
                    <TextView
                        android:id="@+id/textUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PocketBudget"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/iconPrivacyEye"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_icon_btn"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="Toggle privacy"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/iconNotification"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_icon_btn"
                    android:src="@drawable/ic_bell"
                    android:contentDescription="Notifications"/>
            </LinearLayout>

            <!-- ═══ BALANCE CARD ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_balance_card"
                    android:minHeight="174dp"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="2dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total spent"
                            android:textSize="12sp"
                            android:textColor="#80FFFFFF"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:fontFamily="sans-serif"/>
                        <TextView
                            android:id="@+id/textCurrentPeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="May 2026"
                            android:textSize="11sp"
                            android:textColor="@color/brand_dark_green"
                            android:background="@drawable/bg_period_badge"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"/>
                    </LinearLayout>

                    <!-- Main amount + eye toggle -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:id="@+id/textExpenseAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="34sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@android:color/white"
                            android:letterSpacing="0"/>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_eye"
                            app:tint="@color/white_35"
                            android:layout_marginStart="10dp"
                            android:contentDescription="Amount visibility"/>
                    </LinearLayout>

                    <!-- textBalanceSummary -->
                    <TextView
                        android:id="@+id/textBalanceSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#80FFFFFF"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="sans-serif"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#1AFFFFFF"
                        android:layout_marginBottom="10dp"/>

                    <!-- textIncomeAmount / txn count / net -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/textIncomeAmount"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="16sp" android:fontFamily="sans-serif-medium"
                                android:textColor="@android:color/white"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Income" android:textSize="11sp" android:textColor="#B3FFFFFF"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <View android:layout_width="0.5dp" android:layout_height="28dp"
                            android:background="#1AFFFFFF"/>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/textTxnCount"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="16sp" android:fontFamily="sans-serif-medium"
                                android:textColor="@android:color/white"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Transactions" android:textSize="11sp" android:textColor="#B3FFFFFF"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ TIME RANGE TABS ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="14dp"
                android:gravity="center_vertical">

                <TextView android:id="@+id/tabDay"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:gravity="center"
                    android:text="Today" android:textSize="13sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_tab_selected"/>
                <TextView android:id="@+id/tabWeek"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:gravity="center"
                    android:text="Week" android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_tab_default"/>
                <TextView android:id="@+id/tabMonth"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:gravity="center"
                    android:text="Month" android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_tab_default"/>
                <TextView android:id="@+id/tabYear"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:gravity="center"
                    android:text="Year" android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_tab_default"/>
            </LinearLayout>

            <!-- ═══ QUICK ACTIONS ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <!-- actionSync -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/actionSync"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:background="@drawable/bg_qa_green_light"
                        android:src="@drawable/ic_refresh"
                        app:tint="@color/brand_dark_green"
                        android:padding="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sync SMS" android:textSize="9sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" android:gravity="center"/>
                </LinearLayout>

                <!-- actionAdd -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/actionAdd"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:background="@drawable/bg_qa_green_filled"
                        android:src="@drawable/ic_plus"
                        app:tint="@android:color/white"
                        android:padding="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Add" android:textSize="9sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" android:gravity="center"/>
                </LinearLayout>

                <!-- actionBudget -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/actionBudget"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:background="@drawable/bg_qa_amber"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/brand_amber"
                        android:padding="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Budgets" android:textSize="9sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" android:gravity="center"/>
                </LinearLayout>

                <!-- actionAnalytics -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/actionAnalytics"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:background="@drawable/bg_qa_indigo"
                        android:src="@drawable/ic_chart_bar"
                        app:tint="@color/brand_indigo"
                        android:padding="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Analytics" android:textSize="9sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ TOP RECIPIENTS (layoutTopRecipients) ═══ -->
            <LinearLayout
                android:id="@+id/layoutTopRecipients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Top spenders"
                        android:textSize="17sp" android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="See all" android:textSize="13sp"
                        android:textColor="@color/brand_dark_green" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerTopRecipients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <!-- ═══ RECENT TRANSACTIONS ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Recent transactions"
                        android:textSize="17sp" android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"/>
                    <TextView android:id="@+id/btnSeeAll"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="See all" android:textSize="13sp"
                        android:textColor="@color/brand_dark_green" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRecentTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

                <!-- layoutEmptyState -->
                <include
                    android:id="@+id/layoutEmptyState"
                    layout="@layout/layout_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Bottom padding for nav bar -->
            <View android:layout_width="match_parent" android:layout_height="20dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
