<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="132dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginEnd="10dp"
    android:background="@drawable/bg_actor_card"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar with initials -->
    <FrameLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginBottom="10dp">

        <View
            android:id="@+id/view_avatar_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_button"/>

        <TextView
            android:id="@+id/text_actor_initials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"/>
    </FrameLayout>

    <!-- Name -->
    <TextView
        android:id="@+id/text_actor_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/text_primary"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_marginBottom="3dp"/>

    <!-- Amount -->
    <TextView
        android:id="@+id/text_total_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="6dp"/>

    <!-- Relative spend bar -->
    <FrameLayout
        android:id="@+id/frame_spend_bar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/bg_bar_track">

        <View
            android:id="@+id/view_spend_bar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_bar_fill"/>
    </FrameLayout>

    <!-- Txn count -->
    <TextView
        android:id="@+id/text_txn_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="sans-serif"
        android:layout_marginTop="4dp"/>

</LinearLayout>
