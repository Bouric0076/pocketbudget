<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Transaction"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"/>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_close_btn"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#F0F0F0"/>

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- toggleType: Income / Expense -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:background="@drawable/bg_toggle_track">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_income"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Income"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    style="@style/Widget.App.ToggleButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_expense"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Expense"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    style="@style/Widget.App.ToggleButton"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Amount focal zone — editAmount / layoutAmount -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Amount"
                style="@style/Widget.App.AmountInput"
                app:prefixText="KES "
                app:prefixTextColor="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description — editNote / layoutNote -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Description (e.g. Naivas Supermarket)"
                style="@style/Widget.App.RoundedInput"
                app:startIconDrawable="@drawable/ic_pencil"
                app:startIconTint="@color/text_tertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category quick chips -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATEGORY"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:singleSelection="true"
                app:selectionRequired="false"/>

            <!-- editCategory / layoutCategory — full dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Or search all categories"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:startIconDrawable="@drawable/ic_tag"
                app:startIconTint="@color/text_tertiary"
                app:boxCornerRadiusTopStart="11dp"
                app:boxCornerRadiusTopEnd="11dp"
                app:boxCornerRadiusBottomStart="11dp"
                app:boxCornerRadiusBottomEnd="11dp">

                <AutoCompleteTextView
                    android:id="@+id/editCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- switchRecurring + label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_recurring_row"
                android:padding="13dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recurring transaction"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Repeat automatically on a schedule"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchRecurring"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    app:thumbTint="@color/switch_thumb_selector"
                    app:trackTint="@color/switch_track_selector"/>
            </LinearLayout>

            <!-- layoutFrequency — GONE by default, shown when switchRecurring on -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutFrequency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Frequency"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:startIconDrawable="@drawable/ic_repeat"
                app:startIconTint="@color/text_tertiary"
                app:boxCornerRadiusTopStart="11dp"
                app:boxCornerRadiusTopEnd="11dp"
                app:boxCornerRadiusBottomStart="11dp"
                app:boxCornerRadiusBottomEnd="11dp">

                <AutoCompleteTextView
                    android:id="@+id/editFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="13sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- btnSaveTransaction -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveTransaction"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Transaction"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/brand_dark_green"
                app:elevation="0dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
