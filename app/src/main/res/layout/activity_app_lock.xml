<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/brand_dark_green">

    <ImageView
        android:id="@+id/img_lock_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_lock_lock"
        app:tint="@color/brand_light_green"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/text_lock_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PocketBudget Locked"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/text_lock_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter PIN to unlock"
        android:textColor="@color/brand_background_gray"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <!-- Simple PIN View using EditText or multiple boxes -->
    <EditText
        android:id="@+id/edit_pin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:background="@drawable/bg_rounded_edittext" 
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:textSize="24sp"
        android:letterSpacing="0.5"
        android:layout_marginBottom="24dp" />
        
    <!-- We need a drawable for this, but standard edittext is fine for now if styled -->

    <Button
        android:id="@+id/btn_unlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unlock"
        android:backgroundTint="@color/brand_light_green"
        android:textColor="@color/brand_dark_green" />

    <Button
        android:id="@+id/btn_biometric"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use Biometric"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textColor="@color/brand_light_green"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>
