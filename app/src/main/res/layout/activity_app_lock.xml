<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        android:layout_centerInParent="true">

        <ImageView
            android:id="@+id/img_lock_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_launcher_foreground"
            app:tint="@color/brand_light_green"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/text_lock_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_lock_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your PIN to continue"
            android:textColor="@color/text_hint"
            android:textSize="16sp"
            android:layout_marginBottom="48dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/pin_input_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            app:boxStrokeColor="@color/brand_light_green"
            app:hintTextColor="@color/brand_light_green"
            android:textColorHint="@color/text_hint"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:maxLength="4"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="24sp"
                android:letterSpacing="0.3"/>

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:padding="24dp">

        <Button
            android:id="@+id/btn_unlock"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Unlock"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            android:backgroundTint="@color/brand_light_green"
            android:textColor="@color/brand_dark_green" />

        <Button
            android:id="@+id/btn_biometric"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Use Biometric"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/brand_light_green"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>

</RelativeLayout>
