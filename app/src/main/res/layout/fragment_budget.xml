<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background_gray">

    <!-- Scrollable Content -->
    <!-- Starts below header approx height 200dp -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_budget"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="320dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_budget"/>

    <!-- Fixed Header -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_rounded"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Budget"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <ImageView
                android:id="@+id/btn_add_budget"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_input_add"
                android:background="@drawable/bg_button_secondary"
                android:padding="8dp"
                app:tint="@color/brand_light_green"/>
        </LinearLayout>

        <!-- Total Budget Summary Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#20FFFFFF"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Monthly Budget"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:textAllCaps="true"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="bottom">
                    
                    <TextView
                        android:id="@+id/text_total_spent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ksh 0"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:id="@+id/text_total_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" / Ksh 0"
                        android:textColor="#CCFFFFFF"
                        android:textSize="16sp"
                        android:layout_marginBottom="2dp"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_total"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progressDrawable="@drawable/bg_progress_bar"
                    android:progress="0"
                    android:max="100"/>
                    
                <TextView
                    android:id="@+id/text_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ksh 0 remaining"
                    android:textColor="@color/brand_light_green"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:layout_gravity="end"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
